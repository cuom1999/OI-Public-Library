\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{oipl-vn}[2026/07/01 Vietnamese style for OI Public Library translations]

\RequirePackage[a4paper,margin=2.6cm]{geometry}
\RequirePackage{fontspec}
\RequirePackage{mathtools}
\RequirePackage{unicode-math}
\RequirePackage{microtype}
\RequirePackage{enumitem}
\RequirePackage{hyperref}
\RequirePackage{xcolor}

\setmainfont{TeX Gyre Termes}
\setsansfont{TeX Gyre Heros}
\setmonofont{DejaVu Sans Mono}[Scale=MatchLowercase]
\setmathfont{TeX Gyre Termes Math}

\hypersetup{
  colorlinks=true,
  linkcolor=blue!45!black,
  urlcolor=blue!45!black,
  citecolor=blue!45!black,
  pdfauthor={OI Public Library Vietnamese Translation}
}

\setlength{\parindent}{1.5em}
\setlength{\parskip}{0.25em}
\linespread{1.06}

\setlist{itemsep=0.2em,topsep=0.4em}
\setlist[enumerate,1]{label=\arabic*.,leftmargin=2.2em}

\newcommand{\term}[1]{\textbf{#1}}
\newcommand{\origtitle}[1]{\par\smallskip\noindent\textit{Nguồn gốc: #1}\par\smallskip}
\newcommand{\sourcepath}[1]{\par\smallskip\noindent\texttt{#1}\par\smallskip}
